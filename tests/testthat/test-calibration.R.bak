# Tests for calibration and validation functions

test_that("parse_validation_msgs extracts validation metrics", {
  mat_file <- get_synthetic_file("synthetic_01.mat")
  
  mat_data <- read_mat_data(mat_file)
  validation_df <- parse_validation_msgs(mat_data$events)
  
  # Should have 2 rows (pre and post)
  expect_equal(nrow(validation_df), 2)
  
  # Should have expected columns
  expect_named(validation_df, c("id", "time", "type", "avg_err_deg", "max_err_deg", 
                                 "offset_x_px", "offset_y_px", "raw_msg"))
  
  # Should have pre and post types
  expect_setequal(validation_df$type, c("pre", "post"))
  
  # All metrics should be numeric and not NA
  expect_type(validation_df$avg_err_deg, "double")
  expect_type(validation_df$max_err_deg, "double")
  expect_type(validation_df$offset_x_px, "double")
  expect_type(validation_df$offset_y_px, "double")
  
  expect_false(any(is.na(validation_df$avg_err_deg)))
  expect_false(any(is.na(validation_df$max_err_deg)))
  expect_false(any(is.na(validation_df$offset_x_px)))
  expect_false(any(is.na(validation_df$offset_y_px)))
  
  # Validation errors should be positive
  expect_true(all(validation_df$avg_err_deg > 0))
  expect_true(all(validation_df$max_err_deg > 0))
})

test_that("parse_validation_msgs handles missing calibration events gracefully", {
  # Create events without calibration
  events_no_cal <- tibble::tibble(
    id = "TEST01",
    type = c("signal", "response", "image_onset"),
    t = c(100, 200, 300),
    msg = c("signal_on", "response", "image_onset image_001.jpg")
  )
  
  expect_warning(
    result <- parse_validation_msgs(events_no_cal),
    "No calibration events found"
  )
  
  expect_equal(nrow(result), 0)
  expect_named(result, c("id", "time", "type", "avg_err_deg", "max_err_deg",
                         "offset_x_px", "offset_y_px", "raw_msg"))
})

test_that("summarize_validation_relationships computes statistics correctly", {
  # Create simple validation data
  validation_df <- tibble::tibble(
    id = rep(c("P01", "P02"), each = 2),
    time = c(0, 60000, 0, 60000),
    type = rep(c("pre", "post"), 2),
    avg_err_deg = c(0.5, 0.6, 0.4, 0.7),
    max_err_deg = c(1.0, 1.2, 0.9, 1.3),
    offset_x_px = c(10, 12, 8, 15),
    offset_y_px = c(20, 18, 22, 19),
    raw_msg = paste("!CAL VALIDATION", rep(c("pre", "post"), 2))
  )
  
  result <- summarize_validation_relationships(validation_df)
  
  # Should return a list with expected components
  expect_type(result, "list")
  expect_named(result, c("subject_summary", "global_summary", "correlation", "paired_test"))
  
  # Subject summary should have one row per participant
  expect_equal(nrow(result$subject_summary), 2)
  
  # Global summary should have metrics for all fields
  expect_s3_class(result$global_summary, "tbl_df")
  expect_true("metric" %in% names(result$global_summary))
  expect_true("pre_mean" %in% names(result$global_summary))
  expect_true("post_mean" %in% names(result$global_summary))
  expect_true("mean_diff" %in% names(result$global_summary))
  
  # Correlation and paired test may be NULL with small n
  # (need n > 2 for valid statistics)
  expect_true(is.null(result$correlation) || is.list(result$correlation))
  expect_true(is.null(result$paired_test) || is.list(result$paired_test))
})

test_that("summarize_validation_relationships handles single participant", {
  # Single participant
  validation_df <- tibble::tibble(
    id = c("P01", "P01"),
    time = c(0, 60000),
    type = c("pre", "post"),
    avg_err_deg = c(0.5, 0.6),
    max_err_deg = c(1.0, 1.2),
    offset_x_px = c(10, 12),
    offset_y_px = c(20, 18),
    raw_msg = c("!CAL VALIDATION pre", "!CAL VALIDATION post")
  )
  
  result <- summarize_validation_relationships(validation_df)
  
  # Should still compute global summary
  expect_s3_class(result$global_summary, "tbl_df")
  expect_equal(nrow(result$subject_summary), 1)
  
  # Correlation/t-test will be NULL with n < 3
  expect_null(result$correlation)
  expect_null(result$paired_test)
})

describe("Coordinate conversion functions", {
  
  test_that("deg_to_px() converts visual angle to pixels", {
    cfg <- config::get()
    
    # 1 degree should be approximately 36 pixels for typical remote setup
    px_1deg <- deg_to_px(1.0, cfg)
    
    expect_type(px_1deg, "double")
    expect_true(px_1deg > 0)
    expect_true(px_1deg > 20 && px_1deg < 50)  # Reasonable range
  })
  
  test_that("px_to_deg() converts pixels to visual angle", {
    cfg <- config::get()
    
    # Round-trip conversion should be identity
    original_deg <- 2.5
    px <- deg_to_px(original_deg, cfg)
    recovered_deg <- px_to_deg(px, cfg)
    
    expect_equal(recovered_deg, original_deg, tolerance = 1e-6)
  })
  
  test_that("deg_to_px() and px_to_deg() are inverses", {
    cfg <- config::get()
    
    test_values <- c(0.5, 1.0, 2.0, 5.0)
    
    for (deg_val in test_values) {
      px_val <- deg_to_px(deg_val, cfg)
      deg_recovered <- px_to_deg(px_val, cfg)
      expect_equal(deg_recovered, deg_val, tolerance = 1e-10)
    }
  })
  
  test_that("deg_to_px() errors with missing config", {
    bad_cfg <- list(screen = list(width_px = 1280))  # Missing other params
    
    expect_error(
      deg_to_px(1.0, bad_cfg),
      "Missing screen configuration"
    )
  })
  
})

describe("apply_calibration_offsets()", {
  
  test_that("apply_calibration_offsets() adds adjusted coordinate columns", {
    mat_data <- read_mat_data(get_synthetic_file("synthetic_01.mat"))
    validation_df <- parse_validation_msgs(mat_data$events)
    
    samples_adj <- apply_calibration_offsets(
      mat_data$samples,
      validation_df,
      method = "pre"
    )
    
    expect_true("x_px_adj" %in% names(samples_adj))
    expect_true("y_px_adj" %in% names(samples_adj))
    expect_true("offset_x_applied" %in% names(samples_adj))
    expect_true("offset_y_applied" %in% names(samples_adj))
  })
  
  test_that("apply_calibration_offsets() pre method uses constant offsets", {
    mat_data <- read_mat_data(get_synthetic_file("synthetic_01.mat"))
    validation_df <- parse_validation_msgs(mat_data$events)
    
    samples_adj <- apply_calibration_offsets(
      mat_data$samples[1:100, ],
      validation_df,
      method = "pre"
    )
    
    # All offsets should be the same (constant pre-task offset)
    expect_equal(length(unique(samples_adj$offset_x_applied)), 1)
    expect_equal(length(unique(samples_adj$offset_y_applied)), 1)
  })
  
  test_that("apply_calibration_offsets() linear method interpolates", {
    mat_data <- read_mat_data(get_synthetic_file("synthetic_01.mat"))
    validation_df <- parse_validation_msgs(mat_data$events)
    
    samples_adj <- apply_calibration_offsets(
      mat_data$samples,
      validation_df,
      method = "linear"
    )
    
    # Offsets should vary over time (not constant)
    expect_true(length(unique(samples_adj$offset_x_applied)) > 1)
  })
  
  test_that("apply_calibration_offsets() works with LazyFrame input", {
    skip_if_not_installed("tidypolars")
    
    mat_data <- read_mat_data(get_synthetic_file("synthetic_01.mat"))
    validation_df <- parse_validation_msgs(mat_data$events)
    
    # Convert to LazyFrame
    samples_lf <- to_polars_lf(mat_data$samples[1:100, ])
    
    samples_adj_lf <- apply_calibration_offsets(
      samples_lf,
      validation_df,
      method = "pre"
    )
    
    # Should return LazyFrame
    expect_s3_class(samples_adj_lf, "polars_lazy_frame")
    
    # Materialize and check columns
    samples_adj <- to_tibble(samples_adj_lf)
    expect_true("x_px_adj" %in% names(samples_adj))
  })
  
})

describe("compute_zone_radius()", {
  
  test_that("compute_zone_radius() computes average strategy correctly", {
    mat_data <- read_mat_data(get_synthetic_file("synthetic_01.mat"))
    validation_df <- parse_validation_msgs(mat_data$events)
    
    zone_df <- compute_zone_radius(validation_df, strategy = "average", cfg = config::get())
    
    expect_equal(nrow(zone_df), 1)
    expect_named(zone_df, c("id", "r_deg", "r_px", "strategy", "scaling"))
    expect_equal(zone_df$strategy, "average")
    expect_true(zone_df$r_px > 0)
  })
  
  test_that("compute_zone_radius() scaling factor works", {
    mat_data <- read_mat_data(get_synthetic_file("synthetic_01.mat"))
    validation_df <- parse_validation_msgs(mat_data$events)
    cfg <- config::get()
    
    zone_1x <- compute_zone_radius(validation_df, strategy = "average", scaling = 1.0, cfg = cfg)
    zone_2x <- compute_zone_radius(validation_df, strategy = "average", scaling = 2.0, cfg = cfg)
    
    # 2x scaling should double the pixel radius
    expect_equal(zone_2x$r_px, zone_1x$r_px * 2, tolerance = 1e-10)
  })
  
  test_that("compute_zone_radius() errors on negative scaling", {
    mat_data <- read_mat_data(get_synthetic_file("synthetic_01.mat"))
    validation_df <- parse_validation_msgs(mat_data$events)
    cfg <- config::get()
    
    expect_error(
      compute_zone_radius(validation_df, scaling = -0.5, cfg = cfg),
      "Scaling factor must be positive"
    )
  })
  
})

